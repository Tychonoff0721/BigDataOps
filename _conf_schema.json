{
  "test_mode": {
    "description": "测试模式",
    "type": "bool",
    "hint": "开启后使用 Mock 数据进行测试，关闭后从真实 API 采集数据",
    "default": true
  },
  "api_endpoint": {
    "description": "大数据组件 API 端点地址",
    "type": "string",
    "hint": "例如：http://localhost:8088 (Hadoop YARN), http://localhost:8080 (Spark)",
    "default": ""
  },
  "api_username": {
    "description": "API 用户名（如果需要认证）",
    "type": "string",
    "hint": "留空则使用匿名访问",
    "default": ""
  },
  "api_password": {
    "description": "API 密码（如果需要认证）",
    "type": "string",
    "hint": "留空则使用匿名访问",
    "default": ""
  },
  "max_retries": {
    "description": "最大重试次数",
    "type": "int",
    "hint": "网络错误时最大的重试次数",
    "default": 3,
    "min": 1,
    "max": 10
  },
  "timeout_seconds": {
    "description": "请求超时时间（秒）",
    "type": "int",
    "hint": "HTTP 请求的超时时间",
    "default": 30,
    "min": 5,
    "max": 120
  },
  "cache_enabled": {
    "description": "是否启用缓存",
    "type": "bool",
    "hint": "启用后可缓存组件指标数据，减少重复请求",
    "default": true
  },
  "cache_ttl_seconds": {
    "description": "缓存过期时间（秒）",
    "type": "int",
    "hint": "缓存数据的存活时间",
    "default": 300,
    "min": 60,
    "max": 3600
  },
  "proxy_http": {
    "description": "代理地址",
    "type": "string",
    "hint": "IP, 例：192.168.0.x",
    "default": ""
  },
  "port": {
    "description": "端口",
    "type": "string",
    "hint": "代理端口，例：7890",
    "default": ""
  },
  "render_server_url": {
    "description": "RPC 渲染服务器地址",
    "type": "string",
    "hint": "用于远程渲染图片的 RPC 服务器地址",
    "default": ""
  },
  "component_endpoints": {
    "description": "各组件独立 API 端点",
    "type": "object",
    "hint": "为每个组件配置独立的 API 端点，优先级高于 api_endpoint",
    "default": {
      "spark": "",
      "hadoop": "",
      "flink": "",
      "kafka": "",
      "hdfs": "",
      "yarn": ""
    }
  }
}
